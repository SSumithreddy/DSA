def student_grade(marks):
    if marks >= 90:
        print("Grade 0")
    elif marks >= 80:
        print("Grade A+")
    elif marks >= 70:
        print("Grade A")
    elif marks >= 60:
        print("Grade B+")
    elif marks >= 50:
        print("Grade B")
    else:
        print("Fail")
marks = int(input("Enter the marks: "))
student_grade(marks)